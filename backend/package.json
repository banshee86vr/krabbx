    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.23",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^2.1.9"
